{
  "name": "theanother/the-another-multi-brand-global-styles",
  "description": "Define Brands - URL match rules (whole domains or path sections) with per-Brand global style overrides and content variables - on a single WordPress install.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "version": "0.1.0",
  "author": {
    "name": "The Another",
    "email": "hello@theanother.org",
    "url": "https://theanother.org"
  },
  "keywords": [
    "wordpress",
    "plugin",
    "multi-brand",
    "global-styles"
  ],
  "homepage": "https://theanother.org/plugin/multi-brand-global-styles/",
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "automattic/vipwpcs": "^3.0",
    "brain/monkey": "^2.6",
    "johnpbloch/wordpress-core": "^6.9",
    "mockery/mockery": "^1.6",
    "php-stubs/wordpress-stubs": "^6.9",
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^3.9",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "TheAnother\\Plugin\\MultiBrandGlobalStyles\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TheAnother\\Plugin\\MultiBrandGlobalStyles\\Tests\\": "tests/Unit/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "phpcs": "phpcs",
    "phpcbf": "phpcbf",
    "test": "phpunit",
    "build": [
      "@composer install -q --no-dev",
      "@composer dump-autoload -q --no-dev --optimize"
    ]
  }
}
